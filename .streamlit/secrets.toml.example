# Copy to .streamlit/secrets.toml and fill in the password.
# Never commit the real secrets.toml. For Streamlit Cloud, paste these
# same values into the Secrets UI instead of uploading the file.

[connections.snowflake]
account   = "<your-account-identifier>"  # e.g. abcd-12345
user      = "APP_SVC"
password  = "<set in Snowsight for APP_SVC>"
role      = "MA_PAYER_VIEWER"
warehouse = "WH_XS"
database  = "MA_PAYER"
schema    = "MARTS"
